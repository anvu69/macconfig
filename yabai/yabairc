#!/usr/bin/env sh

# =============================================================================
# yabai - Tiling Window Manager for macOS
# Config: ~/.config/yabai/yabairc
# Docs: https://github.com/koekeishiya/yabai/wiki
# =============================================================================

# --- Layout ---
yabai -m config layout                       bsp
yabai -m config window_placement             second_child

# --- Padding & Gaps ---
yabai -m config top_padding                  0
yabai -m config bottom_padding               0
yabai -m config left_padding                 0
yabai -m config right_padding                0
yabai -m config window_gap                   0

# --- Split Ratio ---
yabai -m config auto_balance                 off
yabai -m config split_ratio                  0.5

# --- Mouse ---
yabai -m config mouse_modifier               alt
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize
yabai -m config mouse_follows_focus          off
yabai -m config focus_follows_mouse          off
yabai -m config mouse_drop_action            swap

# --- Window Modifications ---
yabai -m config window_shadow                on
yabai -m config window_opacity               off
yabai -m config active_window_opacity        1.0
yabai -m config normal_window_opacity        0.9

# --- Rules ---
# Float system preferences and other non-tileable apps
yabai -m rule --add app="^System Preferences$" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Finder$" title="(Copy|Bin|About This Mac|Info)" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^App Store$" manage=off
yabai -m rule --add app="^Digital Colour Meter$" manage=off
yabai -m rule --add app="^Disk Utility$" manage=off
yabai -m rule --add app="^Preview$" manage=off
yabai -m rule --add app="^Stickies$" manage=off

echo "yabai configuration loaded..."
